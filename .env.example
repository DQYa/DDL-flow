# DDL Flow AI Configuration
# Copy this file to .env and fill in your actual API credentials

# ==========================================
# OpenAI-compatible API (DeepSeek / OpenAI / 通义千问 etc.)
# ==========================================

# Your API key
AI_API_KEY=your-api-key-here

# Base URL for the chat completions API
# The server will append /chat/completions if not already in the URL
#
# DeepSeek:  https://api.deepseek.com
# OpenAI:    https://api.openai.com/v1
# 通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1
#
# You can also provide the full endpoint path:
#   https://api.deepseek.com/chat/completions
AI_BASE_URL=https://api.deepseek.com

# Model name
# DeepSeek:  deepseek-chat  or  deepseek-v4-flash
# OpenAI:    gpt-4o  or  gpt-4o-mini
AI_MODEL=deepseek-chat

# Optional: change server port
PORT=3001
